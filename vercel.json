{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install && cd backend && npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/health",
      "destination": "/api/index.cjs"
    }
  ],
  "functions": {
    "api/**/*.cjs": {
      "memory": 1024,
      "maxDuration": 60,
      "runtime": "nodejs18.x"
    }
  },
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1"
  }
}

